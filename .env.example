# Contact form delivery — choose one
# A) Email-only via Resend (https://resend.com, 100 emails/day free)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# B) Webhook (Slack, Discord, Make.com, n8n, etc.)
CONTACT_WEBHOOK_URL=

# ─── Stripe (pricing page checkout) ────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_ for development, sk_live_ for production.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Public URL where the hub is served. Used for Stripe Checkout success/cancel URLs.
# In dev: http://localhost:3738  In prod: https://123automateme.com
NEXT_PUBLIC_BASE_URL=https://123automateme.com

# 3 Stripe price IDs (create them in https://dashboard.stripe.com/products).
# These are the "lookup keys" used to find the right Price object in checkout.
# If left blank, the checkout route will create prices on-the-fly using
# STRIPE_PRICE_*_AMOUNT (good for dev/test).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STUDIO=

# Fallback amounts (in cents) for dev when price IDs aren't set.
# Defaults: $19 / $49 / $199 per month.
STRIPE_PRICE_STARTER_AMOUNT=1900
STRIPE_PRICE_PRO_AMOUNT=4900
STRIPE_PRICE_STUDIO_AMOUNT=19900
